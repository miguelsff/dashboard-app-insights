# ── Azure Application Insights ───────────────────────────────────────────────
APPLICATIONINSIGHTS_APP_ID=<application-id-from-app-insights-connection-string>

# Auth options (choose one):
#   1. Local (npm run dev):  az login  — no extra vars needed
#   2. Docker local:         set the 3 vars below (Service Principal)
#   3. Azure Web App:        enable Managed Identity + grant Monitoring Reader role
#
# To create a Service Principal:
#   az ad sp create-for-rbac --name dashboard-reader --role "Monitoring Reader" \
#     --scopes /subscriptions/<sub>/resourceGroups/<rg>/providers/microsoft.insights/components/<name>
# AZURE_TENANT_ID=<tenant-id>
# AZURE_CLIENT_ID=<app-registration-client-id>
# AZURE_CLIENT_SECRET=<client-secret>

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NEXT_PUBLIC_APP_NAME="App Insights Dashboard"
NEXT_PUBLIC_RESOURCE_NAME=<your-app-insights-name>
NEXT_PUBLIC_SERVICE_NAME=<your-service-name>

# ── Azure Container Registry ──────────────────────────────────────────────────
ACR_NAME=<acr-name-without-azurecr-io>
IMAGE_TAG=latest

# ── Azure Web App ─────────────────────────────────────────────────────────────
RESOURCE_GROUP=<resource-group-name>
WEBAPP_NAME=<webapp-name>
WEBAPP_PLAN=<app-service-plan-name>
LOCATION=eastus
